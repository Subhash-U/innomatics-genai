        "from transformers import GenerationConfig\n",
        "\n",
        "def get_chatbot_response(user_input):\n",
        "\n",
        "    context = (\n",
        "        \"Fact-based Assistant Instructions:\\n\"\n",
        "        \"1. Answer the question accurately.\\n\"\n",
        "        \"2. Do not tell personal stories.\\n\"\n",
        "        f\"Question: {user_input}\\n\"\n",
        "        \"Answer:\"\n",
        "    )\n",
        "\n",
        "    # Using 'do_sample=False' (Greedy Search) is the ONLY way to stop\n",
        "    # GPT-2 from hallucinating about being an NPC or a professor.\n",
        "    gen_config = GenerationConfig(\n",
        "        max_new_tokens=40,\n",
        "        do_sample=False,          # Greedy Search for factual integrity\n",
        "        repetition_penalty=1.5,\n",
        "        pad_token_id=50256,\n",
        "        eos_token_id=50256\n",
        "    )\n",
        "\n",
        "    # Generate the response\n",
        "    outputs = generator(\n",
        "        context,\n",
        "        generation_config=gen_config,\n",
        "        max_length=None\n",
        "    )\n",
        "\n",
        "    # Extract the response\n",
        "    full_text = outputs[0]['generated_text']\n",
        "    response = full_text.split(\"Answer:\")[-1].strip()\n",
        "\n",
        "    # Clean up trailing text\n",
        "    response = response.split(\"\\n\")[0].split(\"Question:\")[0].strip()\n",
        "\n",
        "    return response"
      ],
      "metadata": {
        "id": "JaP5p29YAtj3"
